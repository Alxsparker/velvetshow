        "countIn": 0,
        "id": "A0000001-0000-0000-0000-000000000001",
        "lightShowID": null,
        "memo": "🎸 INTRO — Here we go!\n\nWelcome to the Velvet Demo Show.\nThis memo appears automatically at the right moment.\n\nYour band, your setlist, your stage.",
        "memoLength": 12,
        "memoTime": 2,
        "shortName": "Intro",
        "sourceShowMemoID": null,
        "startMidiEventID": null,
        "endMidiEventID": null
      },
      {
        "countIn": 0,
        "id": "A0000001-0000-0000-0000-000000000002",
        "lightShowID": null,
        "memo": "💡 MIDI CUE — Warm Light\n\nA MIDI event just fired automatically.\nAny connected lighting, video or show-control software can react instantly.",
        "memoLength": 8,
        "memoTime": 20,
        "shortName": "Warm Light →",
        "sourceShowMemoID": null,
        "startMidiEventID": null,
        "endMidiEventID": null
      },
      {
        "countIn": 0,
        "id": "A0000001-0000-0000-0000-000000000003",
        "lightShowID": null,
        "memo": "🎤 CHORUS — Full energy!\n\nSing it. This memo cues you in\nbefore the chorus hits.",
        "memoLength": 8,
        "memoTime": 60,
        "shortName": "Chorus",
        "sourceShowMemoID": null,
        "startMidiEventID": null,
        "endMidiEventID": null
      }
    ],
    "-1000002": [
      {
        "countIn": 0,
        "id": "A0000002-0000-0000-0000-000000000001",
        "lightShowID": null,
        "memo": "🎹 Piano intro — let it breathe.\n\nThis is your intimate moment.\nSlow down. Connect with the room.",
        "memoLength": 10,
        "memoTime": 3,
        "shortName": "Piano intro",
        "sourceShowMemoID": null,
        "startMidiEventID": null,
        "endMidiEventID": null
      },
      {
        "countIn": 0,
        "id": "A0000002-0000-0000-0000-000000000002",
        "lightShowID": null,
        "memo": "💡 MIDI CUE — Blue Scene\n\nSoft blue wash activated.\nMIDI fired silently in the background.",
        "memoLength": 8,
        "memoTime": 30,
        "shortName": "Blue Scene →",
        "sourceShowMemoID": null,
        "startMidiEventID": -2000002,
        "endMidiEventID": null
      }
    ],
    "-1000003": [
      {
        "countIn": 0,
        "id": "A0000003-0000-0000-0000-000000000001",
        "lightShowID": null,
        "memo": "🎸 Groove time!\n\nFeel the bass. Stay locked with the drummer.\nThis memo keeps you on the same page.",
        "memoLength": 10,
        "memoTime": 5,
        "shortName": "Groove in",
        "sourceShowMemoID": null,
        "startMidiEventID": null,
        "endMidiEventID": null
      },
      {
        "countIn": 0,
        "id": "A0000003-0000-0000-0000-000000000002",
        "lightShowID": null,
        "memo": "⬇ BREAKDOWN — pull back.\n\nHalf tempo. Let the bassist carry it.",
        "memoLength": 8,
        "memoTime": 90,
        "shortName": "Breakdown",
        "sourceShowMemoID": null,
        "startMidiEventID": null,
        "endMidiEventID": null
      }
    ],
    "-1000004": [
      {
        "countIn": 0,
        "id": "A0000004-0000-0000-0000-000000000001",
        "lightShowID": null,
        "memo": "🌌 Electric Sky — ambient bridge.\n\nThis track fades in automatically from the previous one.\nNo button pressed. Velvet Show handled it.",
        "memoLength": 10,
        "memoTime": 5,
        "shortName": "Auto fade in",
        "sourceShowMemoID": null,
        "startMidiEventID": null,
        "endMidiEventID": null
      },
      {
        "countIn": 0,
        "id": "A0000004-0000-0000-0000-000000000002",
        "lightShowID": null,
        "memo": "💡 MIDI CUE — Energy Scene\n\nFull energy blast. Lights, laser, strobes — your call.",
        "memoLength": 8,
        "memoTime": 60,
        "shortName": "Energy Scene →",
        "sourceShowMemoID": null,
        "startMidiEventID": -2000003,
        "endMidiEventID": null
